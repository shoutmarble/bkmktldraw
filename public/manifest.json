{
  "manifest_version": 3,
  "name": "BKMK TLDraw Overlay",
  "version": "0.1.0",
  "description": "Open a local tldraw overlay on top of the current page.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "action": {
    "default_title": "Toggle TLDraw overlay"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["overlay.html", "*.js", "*.css", "assets/*", "chunks/*"],
      "matches": ["<all_urls>"]
    }
  ]
}